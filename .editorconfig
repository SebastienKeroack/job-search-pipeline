# EditorConfig is awesome: https://EditorConfig.org
root = true

[*]
# Non-configurable Prettier behaviors
charset = utf-8
insert_final_newline = true
# Configurable Prettier behaviors
end_of_line = lf
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

# Markdown
[*.md]
trim_trailing_whitespace = false

# Python
[*.py]
indent_style = space
indent_size = 4

# JavaScript
[*.js]
quote_type = double
semi = true
