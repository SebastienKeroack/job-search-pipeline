# ==============================================================================
# Ignore local development and environment files
# ==============================================================================

# Local configuration and environment files (not tracked in git)
.data/
.local/
.env

# Ignore candidate files
# except for *.example.* files, exists.sh, and llm directory with its contents
candidate/*
!candidate/llm
!candidate/exists.sh
!candidate/*.example.*

# ==============================================================================
# Editor and IDE files
# ==============================================================================

# Visual Studio Code workspace settings and folders
.vscode/*
!.vscode/extensions.json
!.vscode/settings_recommended.json

# ==============================================================================
# Build system and artifacts
# ==============================================================================

# Compressed candidate files for Google Drive
build/

# Distribution and build artifacts
*.egg-info/

# ==============================================================================
# Python cache files
# ==============================================================================

__pycache__/
.pytest_cache/

# ==============================================================================
# JavaScript files
# ==============================================================================

node_modules/
package-lock.json
